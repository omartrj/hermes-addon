{
  "manifest_version": 3,
  "name": "Hermes",
  "version": "1.0.0",
  "description": "End-to-end encryption for messaging platforms",
  "permissions": [
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
